{
  "manifest_version": "0.2",
  "name": "garrastazu-laravel-superset-mcp",
  "display_name": "Garrastazu Laravel Superset MCP",
  "version": "1.0.0",
  "description": "Extensao MCP da Garrastazu para conectar o Claude Desktop ao endpoint Laravel Superset via SSE.",
  "author": {
    "name": "Garrastazu"
  },
  "homepage": "https://github.com/garrastazu/garrastazu-laravel-superset-mcp",
  "server": {
    "type": "node",
    "entry_point": "server/bridge.js",
    "mcp_config": {
      "command": "node",
      "args": [
        "${__dirname}/server/bridge.js"
      ],
      "env": {
        "MCP_SERVER_URL": "${user_config.mcp_server_url}",
        "MCP_API_TOKEN": "${user_config.mcp_api_token}"
      }
    }
  },
  "user_config": {
    "mcp_server_url": {
      "type": "string",
      "title": "MCP Server URL",
      "description": "URL do endpoint MCP Laravel Superset.",
      "required": true,
      "default": "http://127.0.0.1:8000/mcp/superset"
    },
    "mcp_api_token": {
      "type": "string",
      "title": "MCP API Token",
      "description": "Token Bearer para autenticacao no servidor MCP Laravel.",
      "required": true,
      "sensitive": true
    }
  },
  "compatibility": {
    "platforms": [
      "win32"
    ]
  }
}
